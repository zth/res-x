{
  "name": "res-x-demo",
  "version": "0.0.0",
  "scripts": {
    "start": "NODE_ENV=production bun run src/Demo.js",
    "build": "NODE_ENV=production bun run build:vite && bun run build:res",
    "build:vite": "vite build",
    "build:res": "rescript",
    "build:sfe": "bun run build && mkdir -p build && NODE_ENV=production bun build --compile --outfile ./build/demo-app ./src/Demo.js",
    "clean:res": "rescript clean",
    "dev:res": "rescript watch",
    "dev:server": "bun --watch run src/Demo.js",
    "dev:vite": "vite",
    "dev": "concurrently 'bun:dev:*'",
    "link:resx": "node scripts/link-local-rescript-x.mjs",
    "postinstall": "node scripts/link-local-rescript-x.mjs"
  },
  "keywords": [
    "rescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "concurrently": "^8.2.1",
    "fast-glob": "^3.3.1",
    "rescript": "12.0.0-rc.3",
    "rescript-bun": "2.1.0",
    "vite": "^4.4.11"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  }
}
