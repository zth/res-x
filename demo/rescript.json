{
  "jsx": {
    "module": "Hjsx",
    "version": 4
  },
  "name": "res-x-demo",
  "sources": {
    "dir": "src",
    "subdirs": true
  },
  "package-specs": {
    "module": "commonjs",
    "in-source": true
  },
  "suffix": ".js",
  "dependencies": ["rescript-x", "rescript-bun"],
  "compiler-flags": [
    "-open RescriptBun",
    "-open RescriptBun.Globals",
    "-open ResX.Globals"
  ]
}
